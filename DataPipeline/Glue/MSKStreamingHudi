def sparkReadStream(mskbroker, kafka_topic):
    try:
        SASL_JAAS_CONFIG = f"""software.amazon.msk.auth.iam.IAMLoginModule required 
        awsRoleArn="{mskrole}";"""

        readStreamDF = (
            spark.readStream.format("kafka")
            .option("kafka.bootstrap.servers", mskbroker)
            .option("subscribe", kafka_topic)
            .option("kafka.security.protocol", "SASL_SSL")
            .option("kafka.sasl.mechanism", "AWS_MSK_IAM")
            .option("aws.access.key.id", access_key)
            .option("aws.secret.access.key", secret_key)
            .option("aws.session.token", session_token)
            # .option(
            #     "kafka.sasl.jaas.config",
            #     "software.amazon.msk.auth.iam.IAMLoginModule required;",
            # )
            .option("kafka.sasl.jaas.config", SASL_JAAS_CONFIG)
            .option(
                "kafka.sasl.client.callback.handler.class",
                "software.amazon.msk.auth.iam.IAMClientCallbackHandler",
            )
            .option("startingOffsets", "earliest")
            .load()
        )
    except Exception as e:
        print("Error while creating spark stream session", e)
        raise
    return readStreamDF


def schemaCreation():
    try:
        json_schema = StructType(
            [
                StructField("campaignName", StringType(), True),
                StructField("vehicleName", StringType(), True),
                StructField("eventId", StringType(), True),
                StructField("collectionEventTime", LongType(), True),
                StructField("dimensions", MapType(StringType(), StringType()), True),
                StructField(
                    "signals",
                    MapType(
                        StringType(),
                        ArrayType(
                            StructType(
                                [
                                    StructField("value", StringType(), True),
                                    StructField("time", LongType(), True),
                                    StructField("dataType", StringType(), True),
                                ]
                            ),
                            True,
                        ),
                        True,
                    ),
                    True,
                ),
            ]
        )
    except:
        # logger.info("Error while create json_schema")
        print("Error while create json_schema")
    return json_schema


def funcRenameCol(df):
    try:
        new_columns = [col.replace(".", "_") for col in df.columns]
        df_renamed = df
        for old_col, new_col in zip(df.columns, new_columns):
            df_renamed = df_renamed.withColumnRenamed(old_col, new_col)
    except Exception as e:
        print("Error while renaming the column", e)
        raise
    return df_renamed


def dataTransformation(
    columnList, timestampColumn, vidCol, tenantIdCol, df, jsonSchema, kafkaTopic
):
    try:
        ## convert the value from byte to string
        df = df.selectExpr(
            "key",
            "cast(value as string) as value",
            "topic",
            "partition",
            "offset",
            "timestamp",
        )
        # df.printSchema()
        ## parse the value, json by providing the schema
        df = df.withColumn("value", F.from_json(df["value"], jsonSchema)).select(
            "value.*", "timestamp", "key", "topic", "partition", "offset"
        )
        # df.printSchema()
        ## date time column month and year
        df = (
            df.select(columnList)
            .withColumn(
                timestampColumn + "_cal",
                F.from_unixtime(
                    (F.col(timestampColumn) / 1000).cast(DoubleType()),
                    "yyyy-MM-dd hh:mm:ss.SSS",
                ),
            )
            .withColumn("year", F.year(F.col(timestampColumn + "_cal")))
            .withColumn("month", F.month(F.col(timestampColumn + "_cal")))
            .withColumn("day", F.dayofmonth(F.col(timestampColumn + "_cal")))
            .withColumn("hour", F.hour(F.col(timestampColumn + "_cal")))
            .withColumn(
                timestampColumn + "_ts",
                (F.col(timestampColumn + "_cal")).cast(TimestampType()),
            )
            .withColumn("kafka_topic", F.lit(kafkaTopic))
        )
        # df.printSchema()
        df = df.drop(timestampColumn + "_cal")
        ### renaming . to _
        df_renamed = funcRenameCol(df)
        df_renamed = df_renamed.withColumn(
            "vehiclename", df_renamed[vidCol]
        ).withColumn("tenantID", df_renamed[tenantIdCol])
        print(df_renamed.printSchema())
    except Exception as e:
        print("Error while transforming the data", e)
        raise

    return df_renamed


def hudiOptions(
    hudi_raw_db_name,
    hudi_raw_table_name,
    hudi_partition_path,
    hudi_recordkey,
    hudi_s3_output_path,
    hudi_precombine_field,
):
    try:
        hudi_options = {
            "hoodie.table.name": hudi_raw_table_name,
            "hoodie.datasource.write.storage.type": "COPY_ON_WRITE",
            "hoodie.datasource.write.operation": "upsert",
            "hoodie.datasource.write.recordkey.field": hudi_recordkey,
            "hoodie.datasource.write.precombine.field": hudi_precombine_field,
            "hoodie.datasource.write.partitionpath.field": hudi_partition_path,
            "hoodie.datasource.write.hive_style_partitioning": "true",
            "hoodie.datasource.hive_sync.enable": "true",
            "hoodie.datasource.hive_sync.database": hudi_raw_db_name,
            "hoodie.datasource.hive_sync.table": hudi_raw_table_name,
            "hoodie.datasource.hive_sync.partition_fields": hudi_partition_path,
            "hoodie.datasource.hive_sync.partition_extractor_class": "org.apache.hudi.hive.MultiPartKeysValueExtractor",
            "hoodie.datasource.hive_sync.use_jdbc": "false",
            "hoodie.datasource.hive_sync.mode": "hms",
            "path": hudi_s3_output_path,
            "hoodie.parquet.max.file.size": "134217728",
        }
        print("hudi_options====>", hudi_options)
    except Exception as e:
        print("Error while creating hudi options", e)
        raise

    return hudi_options
        
def writeStreamData(transformDF, hudiCheckPointPath, hudiOption):
    print(f"printing to console....")
    prntqry = transformDF.writeStream.trigger(once=True) \
    .format("console") \
    .outputMode("append") \
    .option("truncate", False) \
    .start().awaitTermination()

    query = (
        transformDF.writeStream.trigger(once=True)
        .format("org.apache.hudi")
        .option("checkpointLocation", hudiCheckPointPath)
        .options(**hudiOption)
        .outputMode("append")
        .start().awaitTermination()
    )



