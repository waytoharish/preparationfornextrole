def DbCreation(db_name, s3_bucket, raw_layer_prefix):
    try:
        db_creation_str = (
            f"create database {db_name} location 's3://{s3_bucket}/{raw_layer_prefix}"
        )
        spark.sql(db_creation_str)
    except:
